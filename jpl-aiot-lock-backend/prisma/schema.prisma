generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  PENDING
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum LockStatus {
  ACTIVE
  INACTIVE
  LOCKED
  UNLOCKED
  MAINTENANCE
  LOST_SIGNAL
  LOW_BATTERY
  BLOCKED
}

enum LockConnectionType {
  IOT
  BLUETOOTH
  LORA
  NB_IOT
  LTE
  WIFI
  API_EXTERNAL
  UNKNOWN
}

enum LockConnectionStatus {
  ONLINE
  OFFLINE
  SLEEP
  LOST_SIGNAL
  UNKNOWN
}

enum AccessStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  REVOKED
}

enum AccessType {
  OPEN
  CLOSE
  OPEN_CLOSE
  ADMIN
  VIEW_ONLY
}

enum CommandType {
  OPEN
  CLOSE
  LOCK
  UNLOCK
  SYNC
  RESET
  REQUEST_STATUS
  REQUEST_LOCATION
}

enum CommandStatus {
  PENDING
  SENT
  ACKNOWLEDGED
  SUCCESS
  FAILED
  EXPIRED
  CANCELLED
}

enum LockEventType {
  OPENED
  CLOSED
  OPEN_REQUESTED
  CLOSE_REQUESTED
  ACCESS_GRANTED
  ACCESS_DENIED
  COMMAND_SENT
  COMMAND_SUCCESS
  COMMAND_FAILED
  LOW_BATTERY
  SIGNAL_LOST
  SIGNAL_RESTORED
  TAMPER_ALERT
  GPS_UPDATED
  GEOFENCE_EXIT
  GEOFENCE_ENTER
  MAINTENANCE_STARTED
  MAINTENANCE_FINISHED
  DEVICE_REGISTERED
  DEVICE_UPDATED
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  ASSIGN
  REVOKE
  OPEN_LOCK
  CLOSE_LOCK
  SEND_COMMAND
  SYSTEM_EVENT
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  passwordHash String
  phone        String?
  status       UserStatus    @default(ACTIVE)
  companyId    String?
  roleId       String?
  lastLoginAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  company      Company?      @relation(fields: [companyId], references: [id])
  role         Role?         @relation(fields: [roleId], references: [id])
  lockAccesses LockAccess[]
  commands     LockCommand[]
  events       LockEvent[]
  auditLogs    AuditLog[]

  @@index([companyId])
  @@index([roleId])
  @@index([status])
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  users       User[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(uuid())
  code        String           @unique
  name        String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model Company {
  id        String        @id @default(uuid())
  name      String
  rut       String?
  email     String?
  phone     String?
  address   String?
  status    CompanyStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?
  users     User[]
  branches  Branch[]
  locks     Lock[]
  geofences Geofence[]

  @@index([status])
}

model Branch {
  id        String    @id @default(uuid())
  name      String
  address   String?
  city      String?
  region    String?
  companyId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  locks     Lock[]

  @@index([companyId])
}

model Lock {
  id               String               @id @default(uuid())
  name             String
  internalCode     String               @unique
  serialNumber     String?              @unique
  imei             String?              @unique
  macAddress       String?              @unique
  status           LockStatus           @default(ACTIVE)
  connectionType   LockConnectionType   @default(UNKNOWN)
  connectionStatus LockConnectionStatus @default(UNKNOWN)
  batteryLevel     Int?
  signalLevel      Int?
  firmwareVersion  String?
  hardwareVersion  String?
  lastConnectionAt DateTime?
  lastSyncAt       DateTime?
  companyId        String?
  branchId         String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  deletedAt        DateTime?
  company          Company?             @relation(fields: [companyId], references: [id])
  branch           Branch?              @relation(fields: [branchId], references: [id])
  accesses         LockAccess[]
  events           LockEvent[]
  commands         LockCommand[]
  locations        LockLocation[]
  alerts           Alert[]
  maintenance      MaintenanceRecord[]

  @@index([companyId])
  @@index([branchId])
  @@index([status])
  @@index([connectionType])
  @@index([connectionStatus])
}

model LockAccess {
  id              String       @id @default(uuid())
  userId          String
  lockId          String
  accessType      AccessType   @default(OPEN_CLOSE)
  status          AccessStatus @default(ACTIVE)
  validFrom       DateTime?
  validTo         DateTime?
  allowedDays     String?
  allowedFromTime String?
  allowedToTime   String?
  createdById     String?
  reason          String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  revokedAt       DateTime?
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lock            Lock         @relation(fields: [lockId], references: [id], onDelete: Cascade)

  @@unique([userId, lockId])
  @@index([userId])
  @@index([lockId])
  @@index([status])
}

model LockCommand {
  id              String        @id @default(uuid())
  lockId          String
  userId          String?
  type            CommandType
  status          CommandStatus @default(PENDING)
  requestPayload  Json?
  responsePayload Json?
  errorMessage    String?
  sentAt          DateTime?
  acknowledgedAt  DateTime?
  completedAt     DateTime?
  expiresAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  lock            Lock          @relation(fields: [lockId], references: [id], onDelete: Cascade)
  user            User?         @relation(fields: [userId], references: [id])

  @@index([lockId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model LockEvent {
  id           String        @id @default(uuid())
  lockId       String
  userId       String?
  type         LockEventType
  message      String?
  latitude     Float?
  longitude    Float?
  batteryLevel Int?
  signalLevel  Int?
  rawPayload   Json?
  createdAt    DateTime      @default(now())
  lock         Lock          @relation(fields: [lockId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id])

  @@index([lockId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model LockLocation {
  id           String   @id @default(uuid())
  lockId       String
  latitude     Float
  longitude    Float
  accuracy     Float?
  speed        Float?
  heading      Float?
  batteryLevel Int?
  signalLevel  Int?
  source       String?
  rawPayload   Json?
  recordedAt   DateTime @default(now())
  lock         Lock     @relation(fields: [lockId], references: [id], onDelete: Cascade)

  @@index([lockId])
  @@index([recordedAt])
}

model Geofence {
  id          String   @id @default(uuid())
  name        String
  description String?
  companyId   String
  centerLat   Float
  centerLng   Float
  radiusMt    Float
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([isActive])
}

model Alert {
  id             String        @id @default(uuid())
  lockId         String?
  title          String
  message        String
  severity       AlertSeverity @default(INFO)
  status         AlertStatus   @default(OPEN)
  resolvedAt     DateTime?
  acknowledgedAt DateTime?
  rawPayload     Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  lock           Lock?         @relation(fields: [lockId], references: [id])

  @@index([lockId])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
}

model AuditLog {
  id          String      @id @default(uuid())
  userId      String?
  action      AuditAction
  entity      String
  entityId    String?
  description String?
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())
  user        User?       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}

model MaintenanceRecord {
  id             String    @id @default(uuid())
  lockId         String
  title          String
  description    String?
  startedAt      DateTime?
  finishedAt     DateTime?
  technicianName String?
  result         String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lock           Lock      @relation(fields: [lockId], references: [id], onDelete: Cascade)

  @@index([lockId])
}

model Device {
  id                    String    @id @default(uuid())
  providerId            String?   @unique
  deviceId              String    @unique
  name                  String
  deviceType            String    @default("SMART_LOCK")
  productModel          String    @default("G300N")
  companyId             String?
  imei                  String?
  serialNumber          String?
  simNumber             String?
  iccid                 String?
  firmwareVersion       String?
  hardwareVersion       String?
  bluetoothName         String?
  bleMac                String?
  nfcSupported          Boolean   @default(true)
  gpsSupported          Boolean   @default(true)
  loraSupported         Boolean   @default(false)
  remoteUnlockSupported Boolean   @default(true)
  keyboardSupported     Boolean   @default(false)
  batteryLevel          Int?
  signalStrength        Int?
  lockStatus            String?
  shackleStatus         String?
  onlineStatus          String    @default("OFFLINE")
  lastConnectionAt      DateTime?
  lastLocationLat       Float?
  lastLocationLng       Float?
  lastAddress           String?
  status                String    @default("ACTIVE")
  notes                 String?
  metadata              Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime?

  @@index([companyId])
  @@index([status])
  @@index([onlineStatus])
  @@index([deviceType])
  @@index([productModel])
  @@index([imei])
  @@index([serialNumber])
}

model DeviceAlarmPolicy {
  id                String   @id @default(uuid())
  deviceId          String
  receivePhones     String?
  receiveEmails     String?
  pushSmsEnabled    Boolean  @default(false)
  pushEmailEnabled  Boolean  @default(false)
  sendingEventTypes String
  enabled           Boolean  @default(true)
  remarks           String?
  createdById       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([deviceId])
  @@index([enabled])
}

model DeviceCompanyAssignmentHistory {
  id            String   @id @default(uuid())
  deviceId      String
  fromCompanyId String?
  toCompanyId   String
  assignedById  String?
  remarks       String?
  createdAt     DateTime @default(now())

  @@index([deviceId])
  @@index([toCompanyId])
}

model DeviceHistoryData {
  id             String   @id @default(uuid())
  deviceId       String
  deviceName     String?
  deviceType     String?
  productModel   String?
  companyId      String?
  companyName    String?
  reportType     String   @default("REALTIME")
  reportedAt     DateTime @default(now())
  longitude      Float?
  latitude       Float?
  address        String?
  lockStatus     String?
  shackleStatus  String?
  batteryLevel   Int?
  signalStrength Int?
  temperature    Float?
  speed          Float?
  firmwareVersion String?
  rawPayloadJson Json?
  source         String?
  createdAt      DateTime @default(now())

  @@index([deviceId])
  @@index([companyId])
  @@index([reportType])
  @@index([reportedAt])
}

model FirmwareFile {
  id           String    @id @default(uuid())
  deviceType   String
  productModel String
  firmwareType String
  versionName  String
  fileName     String
  originalFileName String?
  filePath     String
  fileSize     Int
  mimeType     String?
  checksum     String?
  description  String?
  uploadedById String?
  uploadedByName String?
  uploadedAt   DateTime  @default(now())
  deletedAt    DateTime?

  @@unique([deviceType, productModel, firmwareType, versionName])
  @@index([deviceType])
  @@index([productModel])
  @@index([firmwareType])
}

model OtaUpgradeRecord {
  id                  String    @id @default(uuid())
  deviceId            String
  deviceName          String?
  productModel        String?
  companyId           String?
  firmwareFileId      String
  firmwareType        String
  fromVersion         String?
  toVersion           String
  targetVersion       String?
  status              String    @default("PENDING")
  progress            Int       @default(0)
  commandId           String?
  commandPayloadJson  Json?
  responsePayloadJson Json?
  errorMessage        String?
  startedAt           DateTime?
  finishedAt          DateTime?
  verifiedAt          DateTime?
  createdById         String?
  createdByName       String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([deviceId])
  @@index([firmwareFileId])
  @@index([status])
  @@index([createdAt])
}

model DeviceDiagnosisLog {
  id             String   @id @default(uuid())
  deviceId       String
  deviceName     String?
  productModel   String?
  companyId      String?
  diagnosisType  String   @default("UNKNOWN")
  logLevel       String   @default("INFO")
  summary        String
  fullLog        String
  rawPayloadJson Json?
  source         String   @default("MOCK")
  attachmentUrl  String?
  uploadedById   String?
  uploadedByName String?
  uploadedAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([deviceId])
  @@index([companyId])
  @@index([diagnosisType])
  @@index([logLevel])
  @@index([uploadedAt])
}

model DeviceTelemetry {
  id           String   @id @default(uuid())
  deviceId     String
  battery      Int?
  signal       Int?
  speed        Float?
  latitude     Float?
  longitude    Float?
  rawPayload   Json?
  recordedAt   DateTime @default(now())

  @@index([deviceId])
  @@index([recordedAt])
}

model DeviceCommand {
  id              String   @id @default(uuid())
  deviceId        String
  userId          String?
  command         String
  commandType     String?
  commandContent  String?
  status          String   @default("pending")
  isReserved      Boolean  @default(false)
  isCancelled     Boolean  @default(false)
  requestedByUserId String?
  operatorName    String?
  payload         Json?
  requestPayload  Json?
  responsePayload Json?
  responseContent String?
  executeWhenOnline Boolean @default(false)
  executionTime   DateTime?
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  completedAt     DateTime?

  @@index([deviceId])
  @@index([status])
  @@index([createdAt])
}

model DeviceEvent {
  id         String   @id @default(uuid())
  deviceId   String
  type       String
  message    String?
  rawPayload Json?
  createdAt  DateTime @default(now())

  @@index([deviceId])
  @@index([type])
  @@index([createdAt])
}

model GeoFence {
  id        String   @id @default(uuid())
  name      String
  companyId String?
  type      String   @default("circle")
  centerLat Float
  centerLng Float
  radiusMt  Float
  isActive  Boolean  @default(true)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([isActive])
}

model DeviceGeoFence {
  id         String   @id @default(uuid())
  deviceId   String
  geofenceId String
  syncedAt   DateTime?
  createdAt  DateTime @default(now())

  @@unique([deviceId, geofenceId])
  @@index([deviceId])
  @@index([geofenceId])
}

model MonitoringAuditLog {
  id          String   @id @default(uuid())
  userId      String?
  deviceId    String?
  action      String
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([deviceId])
  @@index([action])
  @@index([createdAt])
}

model NfcCard {
  id        String   @id @default(uuid())
  cardNo    String   @unique
  holder    String?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DeviceNfcCard {
  id        String   @id @default(uuid())
  deviceId  String
  nfcCardId String
  cardNumber String?
  blockNumber String?
  status    String   @default("ACTIVE")
  syncedAt  DateTime?
  createdById String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([deviceId, nfcCardId])
  @@index([deviceId])
  @@index([nfcCardId])
}

model DeviceParameterSnapshot {
  id        String   @id @default(uuid())
  deviceId  String
  category  String
  parameters Json
  readById  String?
  readAt    DateTime @default(now())
  rawPayload Json?

  @@index([deviceId])
  @@index([category])
  @@index([readAt])
}

model DeviceParameterChangeLog {
  id           String   @id @default(uuid())
  deviceId     String
  parameterKey String
  oldValue     String?
  newValue     String?
  changedById  String?
  commandId    String?
  result       String?
  createdAt    DateTime @default(now())

  @@index([deviceId])
  @@index([parameterKey])
  @@index([commandId])
  @@index([createdAt])
}

model DynamicPasswordAuditLog {
  id        String   @id @default(uuid())
  deviceId  String
  viewedById String?
  ipAddress String?
  userAgent String?
  result    String
  createdAt DateTime @default(now())

  @@index([deviceId])
  @@index([viewedById])
  @@index([createdAt])
}
