generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  PENDING
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum LockStatus {
  ACTIVE
  INACTIVE
  LOCKED
  UNLOCKED
  MAINTENANCE
  LOST_SIGNAL
  LOW_BATTERY
  BLOCKED
}

enum LockConnectionType {
  IOT
  BLUETOOTH
  LORA
  NB_IOT
  LTE
  WIFI
  API_EXTERNAL
  UNKNOWN
}

enum AccessStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  REVOKED
}

enum AccessType {
  OPEN
  CLOSE
  OPEN_CLOSE
  ADMIN
  VIEW_ONLY
}

enum CommandType {
  OPEN
  CLOSE
  LOCK
  UNLOCK
  SYNC
  RESET
  REQUEST_STATUS
  REQUEST_LOCATION
}

enum CommandStatus {
  PENDING
  SENT
  ACKNOWLEDGED
  SUCCESS
  FAILED
  EXPIRED
  CANCELLED
}

enum LockEventType {
  OPENED
  CLOSED
  OPEN_REQUESTED
  CLOSE_REQUESTED
  ACCESS_GRANTED
  ACCESS_DENIED
  COMMAND_SENT
  COMMAND_SUCCESS
  COMMAND_FAILED
  LOW_BATTERY
  SIGNAL_LOST
  SIGNAL_RESTORED
  TAMPER_ALERT
  GPS_UPDATED
  GEOFENCE_EXIT
  GEOFENCE_ENTER
  MAINTENANCE_STARTED
  MAINTENANCE_FINISHED
  DEVICE_REGISTERED
  DEVICE_UPDATED
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  ASSIGN
  REVOKE
  OPEN_LOCK
  CLOSE_LOCK
  SEND_COMMAND
  SYSTEM_EVENT
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  passwordHash String
  phone        String?
  status       UserStatus    @default(ACTIVE)
  companyId    String?
  roleId       String?
  lastLoginAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  company      Company?      @relation(fields: [companyId], references: [id])
  role         Role?         @relation(fields: [roleId], references: [id])
  lockAccesses LockAccess[]
  commands     LockCommand[]
  events       LockEvent[]
  auditLogs    AuditLog[]

  @@index([companyId])
  @@index([roleId])
  @@index([status])
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  users       User[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(uuid())
  code        String           @unique
  name        String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model Company {
  id        String        @id @default(uuid())
  name      String
  rut       String?
  email     String?
  phone     String?
  address   String?
  status    CompanyStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?
  users     User[]
  branches  Branch[]
  locks     Lock[]
  geofences Geofence[]

  @@index([status])
}

model Branch {
  id        String    @id @default(uuid())
  name      String
  address   String?
  city      String?
  region    String?
  companyId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  locks     Lock[]

  @@index([companyId])
}

model Lock {
  id               String              @id @default(uuid())
  name             String
  internalCode     String              @unique
  serialNumber     String?             @unique
  imei             String?             @unique
  macAddress       String?             @unique
  status           LockStatus          @default(ACTIVE)
  connectionType   LockConnectionType  @default(UNKNOWN)
  batteryLevel     Int?
  signalLevel      Int?
  firmwareVersion  String?
  hardwareVersion  String?
  lastConnectionAt DateTime?
  lastSyncAt       DateTime?
  companyId        String?
  branchId         String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  deletedAt        DateTime?
  company          Company?            @relation(fields: [companyId], references: [id])
  branch           Branch?             @relation(fields: [branchId], references: [id])
  accesses         LockAccess[]
  events           LockEvent[]
  commands         LockCommand[]
  locations        LockLocation[]
  alerts           Alert[]
  maintenance      MaintenanceRecord[]

  @@index([companyId])
  @@index([branchId])
  @@index([status])
  @@index([connectionType])
}

model LockAccess {
  id              String       @id @default(uuid())
  userId          String
  lockId          String
  accessType      AccessType   @default(OPEN_CLOSE)
  status          AccessStatus @default(ACTIVE)
  validFrom       DateTime?
  validTo         DateTime?
  allowedDays     String?
  allowedFromTime String?
  allowedToTime   String?
  createdById     String?
  reason          String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  revokedAt       DateTime?
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lock            Lock         @relation(fields: [lockId], references: [id], onDelete: Cascade)

  @@unique([userId, lockId])
  @@index([userId])
  @@index([lockId])
  @@index([status])
}

model LockCommand {
  id              String        @id @default(uuid())
  lockId          String
  userId          String?
  type            CommandType
  status          CommandStatus @default(PENDING)
  requestPayload  Json?
  responsePayload Json?
  errorMessage    String?
  sentAt          DateTime?
  acknowledgedAt  DateTime?
  completedAt     DateTime?
  expiresAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  lock            Lock          @relation(fields: [lockId], references: [id], onDelete: Cascade)
  user            User?         @relation(fields: [userId], references: [id])

  @@index([lockId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model LockEvent {
  id           String        @id @default(uuid())
  lockId       String
  userId       String?
  type         LockEventType
  message      String?
  latitude     Float?
  longitude    Float?
  batteryLevel Int?
  signalLevel  Int?
  rawPayload   Json?
  createdAt    DateTime      @default(now())
  lock         Lock          @relation(fields: [lockId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id])

  @@index([lockId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model LockLocation {
  id           String   @id @default(uuid())
  lockId       String
  latitude     Float
  longitude    Float
  accuracy     Float?
  speed        Float?
  heading      Float?
  batteryLevel Int?
  signalLevel  Int?
  source       String?
  rawPayload   Json?
  recordedAt   DateTime @default(now())
  lock         Lock     @relation(fields: [lockId], references: [id], onDelete: Cascade)

  @@index([lockId])
  @@index([recordedAt])
}

model Geofence {
  id          String   @id @default(uuid())
  name        String
  description String?
  companyId   String
  centerLat   Float
  centerLng   Float
  radiusMt    Float
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([isActive])
}

model Alert {
  id             String        @id @default(uuid())
  lockId         String?
  title          String
  message        String
  severity       AlertSeverity @default(INFO)
  status         AlertStatus   @default(OPEN)
  resolvedAt     DateTime?
  acknowledgedAt DateTime?
  rawPayload     Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  lock           Lock?         @relation(fields: [lockId], references: [id])

  @@index([lockId])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
}

model AuditLog {
  id          String      @id @default(uuid())
  userId      String?
  action      AuditAction
  entity      String
  entityId    String?
  description String?
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())
  user        User?       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}

model MaintenanceRecord {
  id             String    @id @default(uuid())
  lockId         String
  title          String
  description    String?
  startedAt      DateTime?
  finishedAt     DateTime?
  technicianName String?
  result         String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lock           Lock      @relation(fields: [lockId], references: [id], onDelete: Cascade)

  @@index([lockId])
}
